# Supabase — found in your project's Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# AI email import — server-only, never prefix these with NEXT_PUBLIC_
AI_PROXY_URL=https://proxy.blahblah.com
AI_API_KEY=your-ai-proxy-key
AI_MODEL=gpt-4o-mini
